# Comma-separated list of origins allowed to call this API.
# Include both your local dev URL and your production frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio.vercel.app

# Most free hosts (Render/Railway/Fly) inject this automatically — you
# usually don't need to set it yourself, main.go defaults to 8080 locally.
PORT=8080

# Required to view submitted contact-form messages or analytics via the API
# (GET /api/contact, GET /api/analytics/summary). 
ADMIN_TOKEN=
